# =====================================================================
# 翻譯員打卡系統 — 正式環境（Production）環境變數範本
# ---------------------------------------------------------------------
# 使用方式：
#   1. 把這個檔案複製成 backend/.env.production
#         cp backend/.env.production.example backend/.env.production
#   2. 填入下面標記為「【必填】」的欄位（其餘可先留空）
#   3. 執行 scripts/deploy-prod.sh 部署
#
# ⚠️ backend/.env.production 內含密碼與金鑰，絕對不要 commit 進 git。
#    （.gitignore 已設定忽略，請勿手動加回去。）
# =====================================================================


# ---------------------------------------------------------------------
# 部署環境標記
# ---------------------------------------------------------------------
# 固定填 production。後端會用它判斷目前是正式環境。
DEPLOY_ENV=production


# ---------------------------------------------------------------------
# 資料庫（PostgreSQL）  —  使用 compose 內建的 postgres 容器
# ---------------------------------------------------------------------
# DB_HOST 在 Docker 內固定是容器名稱 postgres，不要改成 localhost。
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_NAME=translator_checkin

# 【必填】資料庫密碼。絕對不要用預設的 postgres。
# 產生方式（在終端機執行，把輸出貼上來）：
#     openssl rand -base64 24
# 若你不填，deploy-prod.sh 會自動幫你產生一組並寫回這個檔案。
DB_PASSWORD=


# ---------------------------------------------------------------------
# JWT 登入金鑰
# ---------------------------------------------------------------------
# 【必填】長度必須 ≥ 32 字元，且不能是預設值，否則後端會「拒絕啟動」。
# 產生方式：
#     openssl rand -hex 32
# 若你不填，deploy-prod.sh 會自動幫你產生一組並寫回這個檔案。
# ⚠️ 換掉這個值會讓所有人「目前的登入」立刻失效，需要重新登入。
JWT_SECRET=

# 登入 token 有效時數（預設 24 小時）。一般不用改。
JWT_EXPIRY_HOURS=24


# ---------------------------------------------------------------------
# 管理員初始密碼
# ---------------------------------------------------------------------
# 【建議填】系統「第一次啟動、資料庫還沒有 admin 帳號」時，
# 會用這個密碼建立第一個管理員（帳號：admin@admin.com）。
# 第一次登入後系統會強制你改密碼。
# 若留空，系統會隨機產生一組並印在後端 log 裡（deploy 腳本會幫你撈出來）。
ADMIN_DEFAULT_PASSWORD=


# ---------------------------------------------------------------------
# 伺服器
# ---------------------------------------------------------------------
# 後端在容器內監聽的 port，一般不用改。
PORT=8080
# 上傳照片在容器內的儲存路徑，一般不用改（已綁定到主機資料夾做備份）。
UPLOAD_DIR=/app/uploads


# ---------------------------------------------------------------------
# 帳號安全
# ---------------------------------------------------------------------
MAX_LOGIN_ATTEMPTS=5        # 連續登入失敗幾次後鎖定帳號
LOCK_DURATION_MINUTES=15    # 帳號鎖定持續幾分鐘


# ---------------------------------------------------------------------
# 照片保留
# ---------------------------------------------------------------------
# 0 = 永久保存（預設）。診斷證明等資料需留存多年，故預設永不自動刪除。
# 若日後要恢復「N 天後自動清除」，把這裡改成正整數即可（清理排程每日 03:00）。
# 注意：永久保存會持續佔用硬碟，請安排足夠空間與備份。
PHOTO_RETENTION_DAYS=0


# =====================================================================
# 以下為「選填整合」——你選了全部啟用，請填入對應金鑰。
# 留空的話該功能不會運作，但不影響系統其他部分。
# =====================================================================

# ---------------------------------------------------------------------
# SMTP 寄信（定期匯出報表 email、排班提醒 email 用）
# ---------------------------------------------------------------------
# 範例（Gmail 需用「應用程式密碼」，不是登入密碼）：
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=587
#     SMTP_USER=your-account@gmail.com
#     SMTP_PASSWORD=（16 碼應用程式密碼）
#     SMTP_FROM=your-account@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---------------------------------------------------------------------
# Google Sheets 匯出（把打卡資料匯出到 Google 試算表）
# ---------------------------------------------------------------------
# 步驟：
#   1. Google Cloud Console → IAM → 服務帳號 → 建立金鑰 → 選 JSON
#   2. 把下載的 JSON 檔放到 backend/google-credentials.json
#   3. 在 docker/docker-compose.prod.yml 取消對應 volume 那一行的註解
#   4. 這裡填容器內的路徑（保持下面這個預設即可）
GOOGLE_CREDENTIALS_FILE=/app/google-credentials.json

# ---------------------------------------------------------------------
# LINE 排班提醒（每天推播明日排班）
# ---------------------------------------------------------------------
# 取得方式：LINE Developers → Messaging API channel → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=


# =====================================================================
# 可觀測性（Tracing / Jaeger）——你選了啟用
# =====================================================================
# 後端把追蹤資料送到 compose 內的 jaeger 容器。一般不用改。
# 若日後想關閉追蹤以省資源，把下面這行的註解打開即可：
#     OTEL_TRACES_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317
OTEL_SERVICE_NAME=translator-checkin


# =====================================================================
# Cloudflare Tunnel（對外公開用，選填但建議）
# =====================================================================
# 你的 server 在診所內部、沒有公開 IP，但翻譯員要從外面用手機連，
# 因此用 Cloudflare Tunnel 把系統安全地公開出去（自動 HTTPS、免開防火牆 port）。
#
# 取得 token 的步驟（詳見 docs/PRODUCTION_DEPLOY.md）：
#   1. 把你的網域加入 Cloudflare（免費方案即可）
#   2. Cloudflare Zero Trust → Networks → Tunnels → Create a tunnel
#   3. 選 Cloudflared，建立後它會給你一段 token，貼到下面
#   4. 在 tunnel 的 Public Hostname 設定：
#         你的網域(例 checkin.example.com)  →  Service: HTTP  →  frontend:80
#   5. 部署時加上 --tunnel 參數：  scripts/deploy-prod.sh --tunnel
#
# 若你暫時不用 Tunnel（例如只在內網測試），這格留空即可。
TUNNEL_TOKEN=
