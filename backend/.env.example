# =============================================
# 翻譯員打卡系統 — 後端環境變數範本
# 複製此檔案為 .env 並填入實際值
# =============================================

# --- 資料庫 ---
DB_HOST=localhost           # Docker 內請改為 postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=translator_checkin

# --- JWT 認證 ---
# 必填，長度至少 32 字元，可用以下指令產生：
#   openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY_HOURS=24

# --- 伺服器 ---
PORT=8080
UPLOAD_DIR=./uploads

# --- 管理員初始密碼 ---
# 若未設定，系統首次啟動時會自動產生隨機密碼並印在 log 中
# 設定後只在第一次啟動（DB 尚無 admin 帳號時）生效
ADMIN_DEFAULT_PASSWORD=

# --- Google Sheets 匯出（選填）---
# 將 Google Service Account JSON 放到 backend/google-credentials.json
# 並在 docker-compose.yml 取消對應 volume 注解
# 取得方式：Google Cloud Console → IAM → 服務帳號 → 建立金鑰 → JSON
GOOGLE_CREDENTIALS_FILE=

# --- 電子郵件寄送（定期匯出報表用，選填）---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- LINE Notify（排班提醒用，選填）---
LINE_CHANNEL_ACCESS_TOKEN=

# --- 帳號安全 ---
MAX_LOGIN_ATTEMPTS=5        # 超過次數後鎖定帳號
LOCK_DURATION_MINUTES=15    # 鎖定持續時間（分鐘）

# --- 照片清理 ---
PHOTO_RETENTION_DAYS=90     # 打卡照片保留天數
