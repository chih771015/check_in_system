{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "statusMessage": "記錄 session 起始 HEAD..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-check.sh",
            "asyncRewake": true,
            "statusMessage": "檢查 commit 與 changelog...",
            "rewakeSummary": "需要補齊 commit 或更動報告"
          }
        ]
      }
    ]
  }
}
