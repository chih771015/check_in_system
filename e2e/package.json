{
  "name": "thai-e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright end-to-end tests for the translator check-in system",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "stack:up": "docker-compose -f ../docker/docker-compose.e2e.yml -p thai-e2e up -d --build",
    "stack:down": "docker-compose -f ../docker/docker-compose.e2e.yml -p thai-e2e down -v",
    "reset": "curl -X POST http://localhost:3001/api/test/reset"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
