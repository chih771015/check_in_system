{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@e2e/*": ["./support/*", "./fixtures/*"]
    }
  },
  "include": ["tests/**/*.ts", "support/**/*.ts", "fixtures/**/*.ts", "playwright.config.ts"]
}
